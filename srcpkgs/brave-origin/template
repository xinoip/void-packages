pkgname=brave-origin
version=1.92.16
revision=1
only_for_archs="x86_64"
short_desc="new brave browser"
maintainer="xinoip <xinoip@proton.me>"
hostmakedepends="tar xz"
license="Mozilla Public License Version 2.0"
homepage="https://brave.com"
distfiles="https://brave-browser-apt-nightly.s3.brave.com/pool/main/b/brave-origin-nightly/brave-origin-nightly_${version}_amd64.deb"
checksum=ddd6ec63f4e5c32e70ae39123f056f6d0c34acdda7b84dc958472b9868f631f0
nostrip=yes

do_extract() {
	mkdir -p ${DESTDIR}
	ar x ${XBPS_SRCDISTDIR}/${pkgname}-${version}/brave-origin-nightly_${version}_amd64.deb
}

do_install() {
	tar xf data.tar.xz -C ${DESTDIR}

	# Install the icons
	for size in 16 24 32 48 64 128 256; do
		mkdir -p ${DESTDIR}/usr/share/icons/hicolor/${size}x${size}/apps
		mv ${DESTDIR}/opt/brave.com/brave-origin-nightly/product_logo_${size}.png \
		${DESTDIR}/usr/share/icons/hicolor/${size}x${size}/apps/brave-origin-nightly.png
	done

	# Remove unused icons
	# rm ${DESTDIR}/opt/brave.com/brave-origin-nightly/*.xpm

	# Remove the Debian/Ubuntu crontab
	rm -rf ${DESTDIR}/etc
	rm -rf ${DESTDIR}/opt/brave.com/brave-origin-nightly/cron
}

